# =============================================================================
# Aurinko — Environment Variable Reference
#
# Copy this file to .env (or .envrc for direnv) and fill in real values.
# NEVER commit .env to source control — it's in .gitignore.
#
# Variables marked [REQUIRED in prod] will cause a startup crash if absent
# when MIX_ENV=prod or MIX_ENV=staging.
# Variables marked [OPTIONAL] fall back to the defaults shown here.
# =============================================================================

# -----------------------------------------------------------------------------
# Credentials                                           [REQUIRED in prod]
# Get these from https://aurinko.io → Dashboard → Your Application
# -----------------------------------------------------------------------------
AURINKO_CLIENT_ID=your_client_id_here
AURINKO_CLIENT_SECRET=your_client_secret_here

# HMAC-SHA256 key for verifying inbound webhook payloads.  [RECOMMENDED]
# Without this, Aurinko.Webhook.Verifier.verify/2 always returns
# {:error, :invalid_signature}.
AURINKO_WEBHOOK_SECRET=your_webhook_signing_secret_here

# -----------------------------------------------------------------------------
# API                                                      [OPTIONAL]
# Override the base URL — useful for pointing at a local mock server.
# Default: https://api.aurinko.io/v1
# -----------------------------------------------------------------------------
# AURINKO_BASE_URL=https://api.aurinko.io/v1

# -----------------------------------------------------------------------------
# HTTP Client                                              [OPTIONAL]
# -----------------------------------------------------------------------------

# Receive timeout in milliseconds. Does not include connection establishment.
# Default: 30000
# AURINKO_TIMEOUT_MS=30000

# HTTP connection pool size per host.
# Default: 20
# AURINKO_POOL_SIZE=20

# -----------------------------------------------------------------------------
# Retry                                                    [OPTIONAL]
# Applied on 429 and 5xx responses.
# Delay formula: retry_delay * 2^attempt + rand(0..200)ms
# -----------------------------------------------------------------------------

# Maximum number of retry attempts.
# Default: 3
# AURINKO_RETRY_ATTEMPTS=3

# Base retry delay in milliseconds.
# Default: 500
# AURINKO_RETRY_DELAY_MS=500

# -----------------------------------------------------------------------------
# Cache                                                    [OPTIONAL]
# ETS-backed TTL cache. Keys are namespaced per access token.
# -----------------------------------------------------------------------------

# Enable or disable the cache entirely.
# Default: true
# AURINKO_CACHE_ENABLED=true

# Default TTL for cached GET responses (milliseconds).
# Per-request override: get(token, path, cache_ttl: 30_000)
# Default: 300000 (5 minutes)
# AURINKO_CACHE_TTL_MS=300000

# Maximum number of ETS cache entries before LRU eviction.
# Sizing guide: unique_accounts × distinct_endpoints × 2.5
# At ~1 KB/entry, 10_000 entries ≈ 10 MB.
# Default: 10000
# AURINKO_CACHE_MAX_SIZE=10000

# Background sweep interval to delete expired entries (milliseconds).
# Default: 60000
# AURINKO_CACHE_CLEANUP_MS=60000

# -----------------------------------------------------------------------------
# Rate Limiter                                             [OPTIONAL]
# Token-bucket: per-account bucket + global bucket.
# Effective per-token capacity = RATE_PER_TOKEN + RATE_BURST
# -----------------------------------------------------------------------------

# Enable or disable the rate limiter.
# Default: true
# AURINKO_RATE_LIMITER_ENABLED=true

# Sustained requests/second per Aurinko access token.
# Match your Aurinko plan's per-token limit.
# Default: 10
# AURINKO_RATE_PER_TOKEN=10

# Total requests/second across all tokens combined.
# Default: 100
# AURINKO_RATE_GLOBAL=100

# Burst headroom above the sustained rate.
# Default: 5
# AURINKO_RATE_BURST=5

# -----------------------------------------------------------------------------
# Circuit Breaker                                          [OPTIONAL]
# Three-state (closed → open → half-open) per normalised endpoint path.
# -----------------------------------------------------------------------------

# Enable or disable the circuit breaker.
# Default: true
# AURINKO_CB_ENABLED=true

# Consecutive server/network errors before the circuit opens.
# Default: 5
# AURINKO_CB_THRESHOLD=5

# Milliseconds to stay in the OPEN state before probing (half-open transition).
# Default: 30000
# AURINKO_CB_TIMEOUT_MS=30000

# -----------------------------------------------------------------------------
# Logging                                                  [OPTIONAL]
# Applies to both the :log_level aurinko config key and the Logger level.
# Values: debug | info | warning | error
# Default: info
# -----------------------------------------------------------------------------
# AURINKO_LOG_LEVEL=info
